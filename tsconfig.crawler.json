{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "dist-crawler",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/crawler-server.ts", "src/crawlers/**/*", "src/pipeline/**/*", "src/types/**/*", "src/demo-data.ts"]
}
