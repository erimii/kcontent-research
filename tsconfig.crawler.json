{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-crawler",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "include": [
    "src/crawlers/**/*",
    "src/pipeline/**/*",
    "src/types/**/*",
    "src/crawler-server.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-crawler", "src/index.tsx", "src/renderer.tsx"]
}
